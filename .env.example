# Server
NODE_ENV=development
PORT=5000
APP_URL=http://localhost:5000
CLIENT_URL=http://localhost:5173

# Database (MySQL)
DB_HOST=localhost
DB_PORT=3306
DB_NAME=retreats_traveon
DB_USER=root
DB_PASSWORD=

# JWT
JWT_SECRET=replace_with_a_long_random_string
JWT_EXPIRES_IN=7d

# Admin (seeded on first run)
ADMIN_EMAIL=admin@traveon.com
ADMIN_PASSWORD=Admin@12345
ADMIN_NAME=Super Admin

# Uploads / Cloudinary
UPLOAD_DIR=uploads
MAX_FILE_SIZE_MB=50
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
CLOUDINARY_FOLDER=traveon-retreats

# PWA
PWA_CLIENT_URL=http://localhost:5174

# Email (Brevo Transactional API)
BREVO_API_KEY=
SMTP_FROM="Holiday Seychelles <traveonventures@gmail.com>"
SMTP_TO=
SIGNED_CONTRACT_NOTIFY_EMAIL=vk722413@gmail.com

# OTP behaviour
PWA_OTP_TTL_MIN=10
