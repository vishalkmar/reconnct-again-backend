{
  "name": "retreats-traveon-backend",
  "version": "1.0.0",
  "description": "Backend for Retreats by Traveon",
  "main": "src/server.js",
  "type": "commonjs",
  "scripts": {
    "start": "node src/server.js",
    "dev": "nodemon src/server.js",
    "migrate": "sequelize-cli db:migrate",
    "migrate:undo": "sequelize-cli db:migrate:undo",
    "seed": "sequelize-cli db:seed:all",
    "seed:admin": "node src/seeders/seedAdmin.js",
    "seed:test": "node src/seeders/seedTestData.js",
    "seed:experience": "node src/seeders/seedExperienceTaxonomy.js",
    "seed:demo": "node src/seeders/seedDemoExperiences.js",
    "seed:reconnct-taxonomy": "node src/seeders/seedReconnctTaxonomy.js",
    "cleanup-indexes": "node src/scripts/cleanupIndexes.js"
  },
  "keywords": [
    "retreats",
    "traveon",
    "wellness"
  ],
  "author": "Traveon",
  "license": "ISC",
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "cloudinary": "^2.10.0",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.21.2",
    "express-async-handler": "^1.2.0",
    "express-rate-limit": "^7.4.1",
    "express-validator": "^7.2.0",
    "helmet": "^8.0.0",
    "jsonwebtoken": "^9.0.2",
    "morgan": "^1.10.0",
    "multer": "^1.4.5-lts.1",
    "mysql2": "^3.11.5",
    "nodemailer": "^6.10.1",
    "pdf-lib": "^1.17.1",
    "sequelize": "^6.37.5",
    "slugify": "^1.6.6",
    "socket.io": "^4.8.3",
    "uuid": "^11.0.3"
  },
  "devDependencies": {
    "nodemon": "^3.1.7",
    "sequelize-cli": "^6.6.2"
  }
}
